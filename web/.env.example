# MapTiler API ключ - get free key at https://www.maptiler.com/
# Ако е празно, fallback към OpenStreetMap
VITE_MAPTILER_KEY=

# HERE Geocoding API key — за trip planner address search.
# Get free key at https://platform.here.com/ (30k req/month free).
# Ако е празно, geocoding е disabled и input-ите ще са невъзможни.
VITE_HERE_API_KEY=

# Backend API URL
# Локално: http://localhost:3001
# Production: https://185-52-207-151.nip.io
VITE_API_URL=http://localhost:3001
